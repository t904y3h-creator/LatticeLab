{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "OPTIMIZE_FOR_NATIVE": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "bench",
      "inherits": "base",
      "displayName": "Bench",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_BENCHMARKS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 2
    },
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 2
    },
    {
      "name": "bench",
      "configurePreset": "bench",
      "targets": [
        "benchmarks"
      ],
      "jobs": 2
    }
  ]
}
